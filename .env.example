# Copy this file to .env.local and fill in your real key.
MINI_CLAUDE_API_KEY=sk-...

# Optional overrides
MINI_CLAUDE_MODEL=kimi-k2.6
MINI_CLAUDE_SANDBOX=workspace-write
MINI_CLAUDE_ALLOWED_COMMANDS=
MINI_CLAUDE_MCP_CONFIG=
MINI_CLAUDE_HISTORY_COMPACT_AFTER_CHARS=80000
MINI_CLAUDE_HISTORY_COMPACT_KEEP_MESSAGES=12
MINI_CLAUDE_PROMPT_CACHE=auto
BRAVE_SEARCH_API_KEY=
